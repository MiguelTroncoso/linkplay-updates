# ===== WhatsApp =====
# JID del dueño para recibir alertas de cierre (formato: 569XXXXXXXX@s.whatsapp.net)
OWNER_JID=569XXXXXXXX@s.whatsapp.net

# ===== Notion (opcional, el bot funciona sin esto) =====
# Token de integración interna de Notion (https://www.notion.so/my-integrations)
NOTION_TOKEN=
# ID de la base de datos de Notion donde se registran los leads
NOTION_DATABASE_ID=

# ===== Cerebro de IA + OCR (opcional) =====
# Clave de la API de Claude (https://console.anthropic.com). Activa:
#  1) El cerebro de IA: responde preguntas libres usando knowledge.md/knowledge.local.md
#  2) OCR de comprobantes (leer el monto de la imagen)
# Sin esta clave el bot funciona igual con su menú/fallback.
ANTHROPIC_API_KEY=
# Modelo de IA (opcional). Por defecto claude-haiku-4-5 (rápido y económico).
AI_MODEL=claude-haiku-4-5

# Números que el bot NUNCA debe responder (los que ya te escribieron antes de
# activarlo, conocidos, etc.). Con código de país, sin '+', separados por coma.
# Tus contactos guardados en WhatsApp se ignoran automáticamente; esto es un extra.
IGNORE_NUMBERS=

# ===== Comportamiento =====
# Zona horaria para los cron de seguimiento
TZ=America/Santiago
# Delay mínimo/máximo (ms) antes de enviar, simula escritura humana (anti-ban)
MIN_TYPING_MS=1200
MAX_TYPING_MS=3000
